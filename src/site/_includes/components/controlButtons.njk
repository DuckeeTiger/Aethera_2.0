<div class="controls-wrapper">
    <!-- Theme Toggle -->
    <button class="theme-toggle" onclick="toggleTheme()">
        <span id="theme-icon">🌙</span>
    </button>
    <!-- Language Toggle -->
    <button class="lang-toggle" onclick="toggleLanguage()">
        <img
            id="lang-flag"
            src="/assets/flags/en.svg"
            alt="Language"
        >
    </button>

</div>

