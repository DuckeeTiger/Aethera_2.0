<!-- ========================================= -->
<!-- BASIC PAGE SETUP -->
<!-- ========================================= -->

<meta charset="utf-8">

<!-- Makes the website responsive on mobile -->
<meta name="viewport" content="width=device-width, initial-scale=1.0">


<!-- ========================================= -->
<!-- DYNAMIC META TAGS -->
<!-- ========================================= -->

{% if metatags %}
    {% for name, content in metatags %}

        {% if name.includes("og:") %}
            <meta property="{{ name }}" content="{{ content }}">

        {% else %}
            <meta name="{{ name }}" content="{{ content }}">
        {% endif %}

    {% endfor %}
{% endif %}


