<!-- ========================================= -->
<!-- BASIC PAGE SETUP -->
<!-- ========================================= -->

<meta charset="utf-8">

<!-- Makes the website responsive on mobile -->
<meta name="viewport" content="width=device-width, initial-scale=1.0">


<!-- ========================================= -->
<!-- DYNAMIC META TAGS -->
<!-- ========================================= -->
<!--
This loops through meta tags generated by Digital Garden.
Things like:
- page description
- OpenGraph preview
- Discord embeds
- SEO data
-->

{% if metatags %}
    {% for name, content in metatags %}

        <!-- OpenGraph tags use "property" instead of "name" -->
        {% if name.includes("og:") %}
            <meta property="{{ name }}" content="{{ content }}">

        <!-- Normal meta tags -->
        {% else %}
            <meta name="{{ name }}" content="{{ content }}">
        {% endif %}

    {% endfor %}
{% endif %}


<!-- ========================================= -->
<!-- IMPORT MAP -->
<!-- ========================================= -->
<!--
This maps D3 libraries for the graph view.
Used by the Digital Garden graph visualization.
-->

<script type="importmap">
{
  "imports": {
    "d3-force": "https://cdn.jsdelivr.net/npm/d3-force@3.0.0/+esm",
    "d3-selection": "https://cdn.jsdelivr.net/npm/d3-selection@3.0.0/+esm",
    "d3-zoom": "https://cdn.jsdelivr.net/npm/d3-zoom@3.0.0/+esm",
    "d3-drag": "https://cdn.jsdelivr.net/npm/d3-drag@3.0.0/+esm"
  }
}
</script>


<!-- ========================================= -->
<!-- PIXI.JS -->
<!-- ========================================= -->
<!--
Used by the graph renderer.
Digital Garden uses this for visual effects and rendering.
-->

<script src="https://cdn.jsdelivr.net/npm/pixi.js@7.4.2/dist/pixi.min.js"></script>


<!-- ========================================= -->
<!-- MERMAID -->
<!-- ========================================= -->
<!--
Allows Mermaid diagrams inside notes.

Example:
graph TD
