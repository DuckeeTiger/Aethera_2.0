<script>

function getCurrentSiteLanguage() {
    const path =
        window.location.pathname.toLowerCase();

    if (path.startsWith("/hu/")) {
        return "hu";
    }

    if (path.startsWith("/en/")) {
        return "en";
    }

    const storedLanguage =
        localStorage.getItem("dg-language");

    if (storedLanguage === "hu" || storedLanguage === "en") {
        return storedLanguage;
    }

    return "en";
}

function isTranslatedPage(path) {
    return path.startsWith("/en/") || path.startsWith("/hu/");
}

function normalizeTranslationPath(path) {
    if (!path) return "";

    return path.endsWith("/")
        ? path
        : `${path}/`;
}

async function toggleLanguage() {
    const langFlag =
        document.getElementById("lang-flag");

    const currentLang =
        getCurrentSiteLanguage();

    const targetLang =
        currentLang === "en"
            ? "hu"
            : "en";

    localStorage.setItem(
        "dg-language",
        targetLang
    );

    window.dispatchEvent(
        new CustomEvent("dg-language-changed", {
            detail: targetLang
        })
    );

    if (langFlag) {
        langFlag.src =
            `/assets/flags/${targetLang}.svg`;
    }

    updateFiletreeLanguage();

    const currentPath =
        normalizeTranslationPath(window.location.pathname);

    if (!isTranslatedPage(currentPath)) {
        return;
    }

    try {
        const response =
            await fetch("/assets/translations.json");

        const translations =
            await response.json();

        let matchedTranslation = null;

        for (const trId in translations) {
            const entry = translations[trId];

            if (
                normalizeTranslationPath(entry[currentLang]) === currentPath
            ) {
                matchedTranslation = entry;
                break;
            }
        }

        if (
            matchedTranslation &&
            matchedTranslation[targetLang]
        ) {
            window.location.href =
                matchedTranslation[targetLang];
            return;
        }

        showTranslationToast(targetLang);

    } catch (err) {
        console.error(
            "[DG LANG] Translation lookup failed",
            err
        );
    }
}

function showTranslationToast(targetLang) {
    const existing =
        document.getElementById("translation-toast");

    if (existing) {
        existing.remove();
    }

    const toast =
        document.createElement("div");

    toast.id = "translation-toast";

    if (targetLang === "hu") {
        toast.textContent =
            "A fordítás még nincs kész. Hamarosan érkezik.";
    } else {
        toast.textContent =
            "Translation is not ready yet. Coming soon.";
    }

    toast.style.position = "fixed";
    toast.style.bottom = "24px";
    toast.style.left = "50%";
    toast.style.transform = "translateX(-50%)";

    toast.style.padding = "12px 18px";
    toast.style.borderRadius = "12px";

    toast.style.background = "rgba(30,30,30,0.95)";
    toast.style.color = "white";

    toast.style.zIndex = "99999";

    toast.style.fontSize = "14px";
    toast.style.fontWeight = "500";

    toast.style.boxShadow =
        "0 4px 18px rgba(0,0,0,0.35)";

    toast.style.backdropFilter =
        "blur(8px)";

    document.body.appendChild(toast);

    setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transition =
            "opacity 0.3s ease";
    }, 2500);

    setTimeout(() => {
        toast.remove();
    }, 3000);
}

function updateLanguageIcon() {
    const langFlag =
        document.getElementById("lang-flag");

    if (!langFlag) return;

    const currentLang =
        getCurrentSiteLanguage();

    if (currentLang === "en") {

        langFlag.src =
            "/assets/flags/en.svg";

    } else {

        langFlag.src =
            "/assets/flags/hu.svg";
    }
}

function updateFiletreeLanguage() {
    const currentLang =
        getCurrentSiteLanguage();

    const treeLinks =
        document.querySelectorAll(".filename");

    treeLinks.forEach(link => {
        const href =
            link.getAttribute("href");

        if (!href) return;

        const treeItem =
            link.closest("li");

        if (!treeItem) return;

        if (currentLang === "en") {
            if (href.startsWith("/hu/")) {
                treeItem.style.display = "none";
            } else {
                treeItem.style.display = "";
            }
        }

        if (currentLang === "hu") {
            if (href.startsWith("/en/")) {
                treeItem.style.display = "none";
            } else {
                treeItem.style.display = "";
            }
        }
    });
}

document.addEventListener("DOMContentLoaded", () => {

    updateLanguageIcon();
    updateFiletreeLanguage();

});

</script>